rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isPremium(userId) {
      let user = userDoc(userId).data;
      return user.accountStatus == 'trial' ||
          user.subscriptionStatus == 'active';
    }

    function collectionExists(userId, collectionId) {
      return exists(/databases/$(database)/documents/users/$(userId)/trips/$(collectionId));
    }

    function modifiesProtectedSubscriptionFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'accountStatus',
        'trialUsed',
        'trialStartedAt',
        'trialEndsAt',
        'subscriptionTier',
        'subscriptionStatus',
        'subscriptionEndsAt',
        'subscriptionSource',
        'subscriptionUpdatedAt',
      ]);
    }

    function createsProtectedSubscriptionFields() {
      return request.resource.data.keys().hasAny([
        'accountStatus',
        'trialUsed',
        'trialStartedAt',
        'trialEndsAt',
        'subscriptionTier',
        'subscriptionStatus',
        'subscriptionEndsAt',
        'subscriptionSource',
        'subscriptionUpdatedAt',
      ]);
    }

    function hasValidCollectionShape() {
      return request.resource.data.name is string &&
          request.resource.data.type in ['personal', 'work'] &&
          request.resource.data.status in ['active', 'completed'] &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp;
    }

    function hasValidCollectionLink(userId) {
      return !('collectionId' in request.resource.data) ||
          request.resource.data.collectionId == null ||
          (request.resource.data.collectionId is string &&
              isPremium(userId) &&
              collectionExists(userId, request.resource.data.collectionId));
    }

    match /config/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && !createsProtectedSubscriptionFields();
      allow update: if isOwner(userId) && !modifiesProtectedSubscriptionFields();

      match /receipts/{receiptId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if isOwner(userId) && hasValidCollectionLink(userId);
        allow delete: if isOwner(userId);
      }

      match /trips/{collectionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
            isPremium(userId) &&
            hasValidCollectionShape();
        allow update: if isOwner(userId) &&
            isPremium(userId) &&
            hasValidCollectionShape();
        allow delete: if isOwner(userId) && isPremium(userId);
      }
    }
  }
}
